{
  "queue_dir": ".codex-batch-runner/tasks",
  "log_dir": ".codex-batch-runner/logs",
  "lock_file": ".codex-batch-runner/runner.lock",
  "state_file": ".codex-batch-runner/state.json",
  "codex_command": ["codex", "exec", "--dangerously-bypass-approvals-and-sandbox", "--json"],
  "codex_resume_command": ["codex", "exec", "--dangerously-bypass-approvals-and-sandbox", "resume", "{session_id}", "--json"],
  "manual_cooldown_wake_scheduler": "disabled",
  "manual_cooldown_wake_command": [],
  "auto_review_mechanical_accept": false,
  "auto_review_codex_enabled": false,
  "auto_review_codex_max_calls_per_run": 0,
  "auto_review_codex_max_fix_loops_per_task": 0,
  "auto_review_codex_cooldown_seconds": 1800,
  "auto_review_codex_max_bundle_chars": 120000,
  "auto_review_codex_max_diff_chars": 60000,
  "worktree_mode": "disabled",
  "worktree_root": ".codex-batch-runner/worktrees",
  "stale_lock_seconds": 21600,
  "rate_limit_cooldown_seconds": 1800,
  "default_max_attempts": 5
}
